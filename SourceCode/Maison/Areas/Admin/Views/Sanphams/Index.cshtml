@model  PagedList.IPagedList<Maison.Models.Sanpham>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Quản lý Sản phẩm gốc";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

<style>
    .popupprivate {
        display: none;
        position: fixed;
        left: 35%;
        top: 5%;
        bottom: 5%;
        overflow-y: auto;
        border-radius: 15px;
        z-index: 1050;
        width: 600px;
    }
</style>

<div class="mt-3 d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center py-4">
    <div class="ml-4 pt-10 h4" style="font-weight:bold">Danh sách Sản phẩm</div>
    <div class="buttons ml-4 pr-2 mt-3">
        <button id="addpopup" class="btn btn-sm btn-outline-primary"><span class="fas fa-plus mr-2"></span>Thêm sản phẩm mới</button>
    </div>
</div>

<table class="table table-hover mt-4 m-3">
    <thead>
        <tr>
            <th>Hình ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th>Thương hiệu</th>
            <th>Bảo hành</th>
            <th>Ngày Tạo</th>
            <th>Người Tạo</th>
            <th>Ngày Sửa</th>
            <th>Người Sửa</th>
            <th>Mô tả</th>
            <th>Tùy chọn</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="row-@item.MaSP">
                <td><img src="@item.HinhAnh" style="width: 110px; height: 110px; object-fit: cover; border-radius: 5px;" onerror="this.src='/Content/Images/no-image.png'" /></td>
                <td><span class="font-weight-bold text-primary">@item.TenSP</span></td>
                <td>@item.DanhMuc.TenDM</td>
                <td>@item.Brand.TenBrand</td>
                <td>@item.ThoiHanBaoHanh tháng</td>
                <td>@item.NgayTao</td>
                <td><span class="font-weight-bold">@item.NguoiTao</span></td>
                <td>@item.NgaySua</td>
                <td><span class="font-weight-bold">@item.NguoiSua</span></td>
                <td>@item.MoTa</td>
                <td>
                    <div class="btn-group">
                        <a href="/Admin/BienThes/Index?maSP=@item.MaSP" class="btn btn-sm btn-success mr-2 rounded" title="Quản lý cấu hình chi tiết (RAM, CPU, Giá)">
                            <i class="fas fa-microchip"></i> Cấu hình
                        </a>

                        <button class="btn btn-link text-dark dropdown-toggle dropdown-toggle-split m-0 p-0" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="icon icon-sm"><span class="fas fa-ellipsis-h icon-dark"></span></span>
                        </button>
                        <div class="dropdown-menu">
                            <button class="dropdown-item change" onclick="loaddata(@item.MaSP)"><span class="fas fa-edit mr-2 text-primary"></span>Sửa thông tin chung</button>
                            <button class="dropdown-item text-danger delete" onclick="deleteData(@item.MaSP)"><span class="fas fa-trash-alt mr-2"></span>Xóa</button>
                        </div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="card-footer px-3 border-0 d-flex align-items-center justify-content-between">
    <nav aria-label="Page navigation example">
        <ul class="pagination mb-0">
            @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount

            @Html.PagedListPager(Model, page => Url.Action("Index",
                new { page, pageSize = Model.PageSize, searchString = ViewBag.searchString }))
        </ul>
    </nav>
</div>
@section popup{
    <div class="popup popupprivate border p-5 bg-white shadow-soft" id="popup">
        <div>
            <form id="add-form" onsubmit="return themSanPham()">
                <p id="add-message"></p>
                <h3 class="mb-4 text-center">Tạo Sản Phẩm Mới</h3>

                <label>Tên sản phẩm:</label>
                <input type="text" class="form-control mb-3" name="TenSP" required autofocus>

                <div class="row">
                    <div class="col-md-6">
                        <label>Danh mục:</label>
                        @Html.DropDownList("MaDM", null, "--- Chọn danh mục ---", htmlAttributes: new { @class = "form-control mb-3", @required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>Thương hiệu:</label>
                        @Html.DropDownList("MaBrand", null, "--- Chọn hãng ---", htmlAttributes: new { @class = "form-control mb-3", @required = "required" })
                    </div>
                </div>

                <label>Thời gian bảo hành (Tháng):</label>
                <input type="number" class="form-control mb-3" name="ThoiHanBaoHanh" value="12" required>

                <label>Ảnh đại diện (Thumbnail):</label>
                <input type="file" class="form-control-file mb-3" name="ImageFile" accept="image/*" required>

                <label>Mô tả sản phẩm:</label>
                <textarea class="form-control mb-4" name="MoTa" rows="4"></textarea>

                <button type="submit" class="btn btn-block btn-primary">Lưu sản phẩm gốc</button>
                <div class="btn btn-block border-primary cancelPopup">Hủy</div>
            </form>
        </div>
    </div>
}

@section changepopup{
    <div class="changepopup popupprivate border p-5 bg-white shadow-soft" id="changepopup">
        <div>
            <form id="update-form" onsubmit="return suaSanPham()">
                <p id="update-message"></p>
                <h3 class="mb-4 text-center text-primary">Sửa Sản Phẩm</h3>

                <input type="hidden" id="masp" name="MaSP" />

                <label>Tên sản phẩm:</label>
                <input type="text" class="form-control mb-3" name="TenSP" id="tensp" required>

                <div class="row">
                    <div class="col-md-6">
                        <label>Danh mục:</label>
                        @Html.DropDownList("MaDM", null, "--- Chọn danh mục ---", htmlAttributes: new { @class = "form-control mb-3", @id = "madm", @required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>Thương hiệu:</label>
                        @Html.DropDownList("MaBrand", null, "--- Chọn hãng ---", htmlAttributes: new { @class = "form-control mb-3", @id = "mabrand", @required = "required" })
                    </div>
                </div>

                <label>Thời gian bảo hành (Tháng):</label>
                <input type="number" class="form-control mb-3" name="ThoiHanBaoHanh" id="baohanh" required>

                <label>Đổi ảnh mới (Bỏ qua nếu giữ ảnh cũ):</label>
                <input type="file" class="form-control-file mb-3" name="ImageFile" accept="image/*">

                <label>Mô tả sản phẩm:</label>
                <textarea class="form-control mb-4" name="MoTa" id="mota" rows="4"></textarea>

                <button type="submit" class="btn btn-block btn-primary">Cập nhật thay đổi</button>
                <div class="btn btn-block border-primary cancelPopup">Hủy</div>
            </form>
        </div>
    </div>
}

@section deletepopup{
    <div class="deletepopup popupprivate border p-5 bg-white shadow-soft" id="deletepopup">
        <div>
            <h3 class="text-warning text-center mb-3">Xóa Sản Phẩm</h3>
            <p id="delete-message"></p>
            <input type="hidden" id="delete-masp" name="MaSP" />
            <h6 class="text-center fw-bold mb-4">Các cấu hình (Biến thể) thuộc sản phẩm này cũng sẽ bị mồ côi. Bạn chắc chắn chứ?</h6>

            <button type="button" class="btn btn-block btn-primary" onclick="xoaSanPham()">Chắc chắn</button>
            <div class="btn btn-block border-primary cancelPopup">Hủy</div>
        </div>
    </div>
}

@section Script{
    <script src="~/Content/admin/JS/addpopup.js"></script>
    <script src="~/Content/admin/JS/sanpham.js"></script>
}