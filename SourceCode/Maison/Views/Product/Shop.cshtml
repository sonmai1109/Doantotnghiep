@model PagedList.IPagedList<Maison.Models.Sanpham>
@using PagedList.Mvc;
@using Maison.Models

<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css">

@{
    ViewBag.Title = "Cửa hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var info = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<style>
    .cps-card {
        background: #fff;
        border-radius: 10px;
        padding: 15px;
        border: 1px solid #f0f0f0;
        transition: all 0.3s ease;
        position: relative;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .cps-card:hover {
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transform: translateY(-5px);
            border-color: #d70018;
        }

    .discount-badge {
        position: absolute;
        top: 10px;
        left: -5px;
        background: #d70018;
        color: #fff;
        font-weight: bold;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 0 15px 15px 0;
        z-index: 2;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.2);
    }

    .cps-card-img {
        text-align: center;
        margin-bottom: 15px;
    }

        .cps-card-img img {
            max-width: 100%;
            height: 180px;
            object-fit: contain;
            transition: transform 0.3s;
        }

    .cps-card:hover .cps-card-img img {
        transform: scale(1.05);
    }

    .cps-card-title {
        font-size: 14px;
        font-weight: 600;
        color: #333;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 10px;
        line-height: 1.4;
    }

        .cps-card-title:hover {
            color: #d70018;
        }

    .cps-price-box {
        margin-top: auto;
    }

    .cps-price-new {
        color: #d70018;
        font-size: 16px;
        font-weight: 700;
        display: block;
        margin-bottom: 2px;
    }

    .cps-price-old {
        color: #707070;
        font-size: 13px;
        text-decoration: line-through;
    }

    .pagination-container {
        margin-top: 40px;
        display: flex;
        justify-content: center;
        width: 100%;
    }
</style>

<div class="breadcrumb-area mt-30 mb-4">
    <div class="container">
        <div class="breadcrumb">
            <ul class="d-flex align-items-center">
                <li>@Html.ActionLink("Trang chủ", "Index", "Home")</li>
                @if (ViewBag.DanhMuc == null)
                {
                    <li class="active">@Html.ActionLink("Cửa hàng", "Shop", "Product")</li>
                }
                else
                {
                    <li class="active">@Html.ActionLink((string)ViewBag.DanhMuc.TenDM, "Shop", "Product", new { madm = ViewBag.DanhMuc.MaDM }, new { })</li>
                }
            </ul>
        </div>
    </div>
</div>

<div class="container pb-100">
    // Thay thế đoạn trống sản phẩm của bạn
    @if (Model == null || !Model.Any())
    {
        <div class="text-center" style="margin: 80px 0; border: 1px dashed #ccc; padding: 50px; border-radius: 10px; background: #f9f9f9;">
            @if (!string.IsNullOrEmpty(ViewBag.searchString as string))
            {
                <h4 style="color: gray;"><i class="fas fa-search mb-3" style="font-size:30px;"></i><br />Không tìm thấy sản phẩm nào cho từ khóa: <strong>@ViewBag.searchString</strong></h4>
            }
            else if (ViewBag.Brand != null && ViewBag.DanhMuc != null)
            {
                <h4 style="color: gray;"><i class="fas fa-box-open mb-3" style="font-size:30px;"></i><br />Chưa có sản phẩm "<strong>@ViewBag.Brand.TenBrand</strong>" trong danh mục "<strong>@ViewBag.DanhMuc.TenDanhMuc</strong>".</h4>
            }
            else if (ViewBag.DanhMuc != null)
            {
                <h4 style="color: gray;"><i class="fas fa-box-open mb-3" style="font-size:30px;"></i><br />Không có sản phẩm nào trong danh mục "<strong>@ViewBag.DanhMuc.TenDanhMuc</strong>".</h4>
            }
            else
            {
                <h4 style="color: gray;">Không tìm thấy sản phẩm nào.</h4>
            }
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="cps-card">
                        @{
                            // 1. Tên hiển thị luôn giữ nguyên chuẩn (Không nối cấu hình)
                            string tenHienThi = item.TenSP;

                            // 2. Giá gốc mặc định (Lấy cấu hình rẻ nhất)
                            decimal giaGoc = item.BienThes != null && item.BienThes.Any() ? item.BienThes.Min(b => b.GiaBan) : 0;
                            decimal? giamoi = null;
                            int phanTramMax = 0;

                            // 3. Lấy TẤT CẢ Khuyến mãi đang chạy của sản phẩm này
                            var activeKMs = item.SanPhamKhuyenMais?.Where(k => k.KhuyenMai.TrangThai == 1
                                                && k.KhuyenMai.NgayBatDau <= DateTime.Now
                                                && k.KhuyenMai.NgayKetThuc >= DateTime.Now).ToList();

                            if (activeKMs != null && activeKMs.Any())
                            {
                                // THUẬT TOÁN: Tìm % Giảm giá lớn nhất
                                phanTramMax = activeKMs.Max(k => k.PhanTramGiam);

                                // Tìm ngược lại xem cái % to nhất này thuộc về biến thể nào
                                var bestKM = activeKMs.FirstOrDefault(k => k.PhanTramGiam == phanTramMax);

                                // Nếu thuộc về 1 biến thể cụ thể -> Phải lấy giá gốc của biến thể đó để tính
                                if (bestKM != null && bestKM.MaBT != null)
                                {
                                    var bt = item.BienThes?.FirstOrDefault(b => b.MaBT == bestKM.MaBT);
                                    if (bt != null)
                                    {
                                        giaGoc = bt.GiaBan;
                                    }
                                }

                                // Tính giá mới hiển thị
                                giamoi = giaGoc * (1 - (decimal)phanTramMax / 100);
                            }
                        }

                        @if (phanTramMax > 0)
                        {
                            <div class="discount-badge">Giảm tới @phanTramMax%</div>
                        }

                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-img">
                            <img src="@item.HinhAnh" onerror="this.src='/Content/Images/no-image.png'" alt="@item.TenSP" />
                        </a>

                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-title">
                            @tenHienThi
                        </a>

                        <div class="cps-price-box">
                            @if (giaGoc > 0)
                            {
                                if (phanTramMax > 0)
                                {
                                    <span class="cps-price-new">@string.Format(info, "{0:c0}", giamoi)</span>
                                    <span class="cps-price-old">@string.Format(info, "{0:c0}", giaGoc)</span>
                                }
                                else
                                {
                                    <span class="cps-price-new">@string.Format(info, "{0:c0}", giaGoc)</span>
                                }
                            }
                            else
                            {
                                <span class="cps-price-new text-muted" style="font-size:14px;">Chưa có cấu hình</span>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>

        <div class="pagination-container">
            <ul class="blog-pagination">
                @{
                    string actionName = ViewBag.ActionName ?? "Shop";
                    string searchString = ViewBag.searchString ?? "";
                    int? madm = ViewBag.madm;
                    int? maBrand = ViewBag.maBrand; // Lấy maBrand từ Controller
                }
                @* Nhét thêm maBrand vào Url.Action để phân trang không bị mất lọc *@
                @Html.PagedListPager(Model, page => Url.Action(actionName, new { page, searchString, madm, maBrand }))
            </ul>
        </div>

    }
</div>