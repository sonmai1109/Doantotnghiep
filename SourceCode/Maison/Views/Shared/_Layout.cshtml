<body>
    <header>
        <div class="headfrs text-center">
            <p><span class="dot"> </span> Happy New Year -Vui Tết Tràn Ngập!</p>

        </div>

        <div class="headersc">

            <div class="container">
                <div class="d-flex align-items-center gap-3">

                    <div class="logo">
                        <a href="/Home/Index"><img src="~/Content/client/img/lg.png" /></a>
                    </div>

                    <div class="menu-wrapper">
                        <button class="btn btn-light" id="buttondropmenu"> Danh Mục</button>
                        <ul class="border bg-white text-center dropmenu" id="dropmenu">@{Html.RenderAction("dropdanhmuc", "Home");}</ul>
                    </div>
                    <div class="flex-grow-1">
                        <div class="input-group">

                            <span class="input-group-text bg-white">
                                <i class="fas fa-search "></i>
                            </span>
                            <input type="text"
                                   class="form-control"
                                   placeholder="Bạn muốn tìm gì?">
                        </div>
                    </div>
                    <div class="btn btn-light"><i class="nav-icon fas fa-shopping-cart"></i> Giỏ hàng</div>
                    @if (tk == null)
                    {
                        <div class="btn btn-light" id="clicktk">
                            <i class="nav-icon fas fa-user"></i>

                            Tài khoản
                        </div>
                        <div class="container text-center   pt-5  checktk border" id="checktk">
                            <h3>Bạn đã có tài khoản chưa?</h3>
                            <br />
                            <div class="btn btn-primary">@Html.ActionLink("Đăng nhập", "Login", "Home", null, new { @class = "text-dark text-decoration-none" })</div>
                            <div class="btn btn-danger">@Html.ActionLink("Đăng ký", "Signup", "Home", null, new { @class = "text-dark text-decoration-none" })</div>
                        </div>




                    }

                    <a href="#" class="btn btn-light">
                        <i class="fas fa-phone text-danger"></i>  Liên hệ
                    </a>
                </div>

            </div>

        </div>

    </header>


    <main>

        @RenderBody()

        @*@{Html.RenderAction("test", "Home");}*@


    </main>

    <footer>
    </footer>
    <div class="overlay" id="overlay"></div>
    <script src="~/Content/client/JS/vendor/jquery-3.2.1.min.js"></script>
    <!-- Countdown js -->
    <script src="~/Content/client/JS/jquery.countdown.min.js"></script>
    <!-- Mobile menu js -->
    <script src="~/Content/client/JS/jquery.meanmenu.min.js"></script>
