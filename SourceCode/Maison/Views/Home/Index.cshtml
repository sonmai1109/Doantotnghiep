@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var info = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<style>
    /* CSS Card Sản phẩm mang phong cách CellphoneS */
    .block-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

        .block-title h2 {
            font-size: 22px;
            font-weight: 700;
            text-transform: uppercase;
            color: #333;
            margin: 0;
        }

    .cps-card {
        background: #fff;
        border-radius: 10px;
        padding: 15px;
        border: 1px solid #f0f0f0;
        transition: all 0.3s ease;
        position: relative;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .cps-card:hover {
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            transform: translateY(-5px);
            border-color: #d70018;
        }

    .discount-badge {
        position: absolute;
        top: 10px;
        left: -5px;
        background: #d70018;
        color: #fff;
        font-weight: bold;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 0 15px 15px 0;
        z-index: 2;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.2);
    }

    .cps-card-img {
        text-align: center;
        margin-bottom: 15px;
    }

        .cps-card-img img {
            max-width: 100%;
            height: 180px;
            object-fit: contain;
            transition: transform 0.3s;
        }

    .cps-card:hover .cps-card-img img {
        transform: scale(1.05);
    }

    .cps-card-title {
        font-size: 14px;
        font-weight: 600;
        color: #333;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 10px;
        line-height: 1.4;
    }

        .cps-card-title:hover {
            color: #d70018;
        }

    .cps-price-box {
        margin-top: auto;
    }

    .cps-price-new {
        color: #d70018;
        font-size: 16px;
        font-weight: 700;
        display: block;
    }

    .cps-price-old {
        color: #707070;
        font-size: 13px;
        text-decoration: line-through;
    }
</style>

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:1200:300/q:90/plain/https://dashboard.cellphones.com.vn/storage/sliding-home-iphone-15.jpg" class="w-100 rounded shadow-sm" alt="Banner Khuyến Mãi">
        </div>
    </div>

    <div class="block-title mt-5">
        <h2>🔥 HOT SALE Cuối Tuần</h2>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
        @if (ViewBag.SanPhamKhuyenMai != null)
        {
            foreach (var item in ViewBag.SanPhamKhuyenMai as List<Maison.Models.SanPhamKhuyenMai>)
            {
                var sp = item.Sanpham;

                // Mặc định tên và giá gốc là lấy giá rẻ nhất
                string tenHienThi = sp.TenSP;
                decimal giaGoc = sp.BienThes != null && sp.BienThes.Any() ? sp.BienThes.Min(b => b.GiaBan) : 0;

                // NẾU GIẢM GIÁ RIÊNG CHO 1 CẤU HÌNH (MaBT != null)
                if (item.MaBT != null)
                {
                    var bt = sp.BienThes.FirstOrDefault(b => b.MaBT == item.MaBT);
                    if (bt != null)
                    {
                        giaGoc = bt.GiaBan; // Lấy đúng giá gốc của bản đó

                        // Lấy các thuộc tính chính (RAM, CPU...) ghép lại
                        var ttChinh = bt.ChiTietBTs.Where(c => c.GiaTriTT.ThuocTinh.LaThuocTinhChinh).Select(c => c.GiaTriTT.GiaTri);
                        if (ttChinh != null && ttChinh.Any())
                        {
                            tenHienThi = sp.TenSP + " (" + string.Join(" - ", ttChinh) + ")";
                        }
                    }
                }

                decimal giaGiam = giaGoc * (1 - (decimal)item.PhanTramGiam / 100);

                <div class="col">
                    <div class="cps-card">
                        <div class="discount-badge">Giảm @((int)item.PhanTramGiam)%</div>
                        <a href="@Url.Action("ProductDetail", "Product", new { id = sp.MaSP })" class="cps-card-img">
                            <img src="@sp.HinhAnh" onerror="this.src='/Content/Images/no-image.png'" alt="@sp.TenSP" />
                        </a>
                        <a href="@Url.Action("ProductDetail", "Product", new { id = sp.MaSP })" class="cps-card-title">
                            @tenHienThi
                        </a>
                        <div class="cps-price-box">
                            @if (giaGoc > 0)
                            {
                                <span class="cps-price-new">@string.Format(info, "{0:c0}", giaGiam)</span>
                                <span class="cps-price-old">@string.Format(info, "{0:c0}", giaGoc)</span>
                            }
                            else
                            {
                                <span class="cps-price-new text-muted" style="font-size:14px;">Đang cập nhật giá</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="block-title mt-5">
        <h2>✨ Sản Phẩm Mới Ra Mắt</h2>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
        @if (ViewBag.SanPhamMoi != null)
        {
            foreach (var item in ViewBag.SanPhamMoi as List<Maison.Models.Sanpham>)
            {
                decimal giaMin = item.BienThes != null && item.BienThes.Any() ? item.BienThes.Min(b => b.GiaBan) : 0;

                <div class="col">
                    <div class="cps-card">
                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-img">
                            <img src="@item.HinhAnh" onerror="this.src='/Content/Images/no-image.png'" alt="@item.TenSP" />
                        </a>
                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-title">
                            @item.TenSP
                        </a>
                        <div class="cps-price-box">
                            @if (giaMin > 0)
                            {
                                <span class="cps-price-new">@string.Format(info, "{0:c0}", giaMin)</span>
                            }
                            else
                            {
                                <span class="cps-price-new text-muted" style="font-size:14px;">Đang cập nhật giá</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="block-title mt-5">
        <h2>💰 Giá Tốt Chốt Ngay</h2>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
        @if (ViewBag.GiaTot != null)
        {
            foreach (var item in ViewBag.GiaTot as List<Maison.Models.Sanpham>)
            {
                decimal giaMin = item.BienThes != null && item.BienThes.Any() ? item.BienThes.Min(b => b.GiaBan) : 0;

                <div class="col">
                    <div class="cps-card">
                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-img">
                            <img src="@item.HinhAnh" onerror="this.src='/Content/Images/no-image.png'" alt="@item.TenSP" />
                        </a>
                        <a href="@Url.Action("ProductDetail", "Product", new { id = item.MaSP })" class="cps-card-title">
                            @item.TenSP
                        </a>
                        <div class="cps-price-box">
                            @if (giaMin > 0)
                            {
                                <span class="cps-price-new">@string.Format(info, "{0:c0}", giaMin)</span>
                            }
                            else
                            {
                                <span class="cps-price-new text-muted" style="font-size:14px;">Đang cập nhật giá</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>