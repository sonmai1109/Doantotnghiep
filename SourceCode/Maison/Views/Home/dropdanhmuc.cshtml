@model IEnumerable<Maison.Models.Danhmuc>
@using Maison.Models
@{
    // Khởi tạo DB để truy vấn nhanh Brand theo Danh Mục
    shopdb db = new shopdb();
}

@foreach (var item in Model)
{
    <li class="cat-item">
        <a href="/Home/Category/@item.MaDM" class="d-flex justify-content-between align-items-center text-dark text-decoration-none">
            <span class="font-weight-bold">@item.TenDM</span>
            <i class="fas fa-chevron-right text-muted" style="font-size: 12px;"></i>
        </a>

        <div class="mega-menu-brands shadow-sm border">
            <h6 class="fw-bold mb-3 text-start text-danger border-bottom pb-2">Thương hiệu @item.TenDM</h6>

            <div class="brand-grid">
                @{
                    // Lấy ra các thương hiệu đang có sản phẩm thuộc danh mục này
                    var brands = db.Brands.Where(b => b.Sanphams.Any(s => s.MaDM == item.MaDM)).ToList();
                }

                @if (brands.Count > 0)
                {
                    foreach (var br in brands)
                    {
                        <a href="/Home/Brand/@br.MaBrand" class="brand-item border rounded" title="@br.TenBrand">
                            <img src="@br.Logo" alt="@br.TenBrand" onerror="this.src='/Content/Images/no-image.png'" />
                        </a>
                    }


                    
                }
                else
                {
                    <span class="text-muted" style="font-size: 13px;">Đang cập nhật...</span>
                }
            </div>
        </div>
    </li>
}