@model Maison.Models.TaiKhoanNguoiDung

@{
    ViewBag.Title = "Đăng ký";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg">
                <div class="card-header text-center bg-primary text-white">
                    <h4>Đăng ký tài khoản</h4>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm("SignUp", "Home", FormMethod.Post))
                    {

                        <div class="mb-3">
                            <label>Tên đăng nhập</label>
                            @Html.TextBoxFor(m => m.TenDangNhap, new { @class = "form-control", placeholder = "Nhập tên đăng nhập" })
                            @if (ViewBag.mess != null)
                            {
                                <div class="alert alert-danger mt-1">
                                    @ViewBag.mess
                                </div>

                            }
                            @Html.ValidationMessageFor(m => m.TenDangNhap, "", new { @class = "text-danger" })



                        </div>

                        <div class="mb-3">
                            <label>Mật khẩu</label>
                            @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                            @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Họ tên</label>
                            @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control", placeholder = "Nhập họ tên" })
                            @Html.ValidationMessageFor(m => m.HoTen, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Số điện thoại</label>
                            @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control", placeholder = "Nhập số điện thoại" })
                            @Html.ValidationMessageFor(m => m.SoDienThoai, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Nhập email" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Địa chỉ</label>
                            @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", placeholder = "Nhập địa chỉ" })
                            @Html.ValidationMessageFor(m => m.DiaChi, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Ngày sinh</label>
                            @Html.TextBoxFor(m => m.NgaySinh, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.NgaySinh, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label>Giới tính</label>
                            @Html.DropDownListFor(m => m.GioiTinh,
                                new List<SelectListItem>
                              {
                                 new SelectListItem { Text = "-- Chọn giới tính --", Value = "" },
                                 new SelectListItem { Text = "Nam", Value = "1" },
                                 new SelectListItem { Text = "Nữ", Value = "2" }
                               },
                                 new { @class = "form-control" })

                            @Html.ValidationMessageFor(m => m.GioiTinh, "", new { @class = "text-danger" })
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-success w-100">
                                Đăng ký
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <a href="@Url.Action("Login","Home")">
                                Đã có tài khoản? Đăng nhập
                            </a>
                        </div>

                        <div class="text-danger text-center mt-2">
                            @*@Html.ValidationSummary()*@
                        </div>

                    }

                </div>
            </div>

        </div>
    </div>
</div>